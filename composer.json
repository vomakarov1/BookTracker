{
    "name": "booktracker/booktracker",
    "description": "Система учёта прочитанной литературы",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "symfony/console": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/config": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "BookTracker\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
