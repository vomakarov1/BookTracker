{
  "name": "booktracker/booktracker",
  "description": "Система учёта прочитанной литературы",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "symfony/config": "^7.0",
    "symfony/console": "^7.0",
    "symfony/dependency-injection": "^7.0",
    "symfony/filesystem": "^8.0",
    "symfony/property-access": "^8.0",
    "symfony/property-info": "^8.0",
    "symfony/serializer": "^8.0",
    "symfony/uid": "^8.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^13.1"
  },
  "autoload": {
    "psr-4": {
      "BookTracker\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BookTracker\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
